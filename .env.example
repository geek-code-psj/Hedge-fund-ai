# ── LLM (Gemini — primary, free) ────────────────────────────────────────────
GEMINI_API_KEY=AIzaSy...
GEMINI_MODEL=gemini-2.0-flash

# ── LLM (OpenAI — optional fallback) ────────────────────────────────────────
OPENAI_API_KEY=sk-placeholder
OPENAI_MODEL=gpt-4o-mini

# ── Financial Data APIs ──────────────────────────────────────────────────────
# ⚠️  EODHD (End-of-Day Historical Data) required for prices + fundamentals
# Free tier: Get key @ https://eodhd.com/register (includes 120 daily requests)
# Without key: Price will show as N/A, Sector will be None
EODHD_API_KEY=demo

# ⚠️  FMP (Financial Modeling Prep) required for advanced financials + insider trades
# Free tier: Get key @ https://financialmodelingprep.com (includes 250 daily requests)
# Without key: Insider trades and detailed metrics unavailable
FMP_API_KEY=demo

# Optional: SEC EDGAR data scraping (fallback if APIs down)
# Format: "Your Name your@email.com" — required by SEC server
FINNHUB_API_KEY=d_placeholder
SEC_USER_AGENT="YourName your@email.com"

# ── Storage ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
DATABASE_URL=sqlite+aiosqlite:///./hedge_fund.db

# ── Observability ────────────────────────────────────────────────────────────
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006/v1/traces

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=900
CACHE_SIMILARITY_THRESHOLD=0.92
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Timeouts (seconds) ────────────────────────────────────────────────────────
AGENT_TIMEOUT=20
LLM_TIMEOUT=90
ORCHESTRATOR_TIMEOUT=60

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=30

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
